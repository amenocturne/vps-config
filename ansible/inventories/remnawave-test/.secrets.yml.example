---
# Remnawave Secrets Configuration
# This is the SINGLE secrets file for ALL Remnawave services
# Copy this file to .secrets.yml and fill in the values
# NEVER commit .secrets.yml to git!

# =============================================================================
# PANEL/BACKEND SECRETS (for main panel server)
# =============================================================================

# JWT Secrets (generate with: openssl rand -hex 32)
jwt_auth_secret: "GENERATE_64_CHAR_SECRET_HERE"
jwt_api_tokens_secret: "GENERATE_64_CHAR_SECRET_HERE"

# Metrics authentication
metrics_pass: "GENERATE_STRONG_PASSWORD"

# Webhook secret
webhook_secret: "GENERATE_SECRET_HERE"

# Database password
postgres_password: "GENERATE_STRONG_PASSWORD"

# =============================================================================
# VPN NODES SECRETS (for all VPN node servers)
# =============================================================================

# Node Secret Keys (get from Remnawave Panel when registering each node)
# 
# HOW TO GET SECRET_KEY FOR EACH NODE:
# 1. Go to https://panel.amenocturne.space/nodes
# 2. Click "Add Node"
# 3. Fill in:
#    - Name: "Netherlands" (or your node name)
#    - Address: Node's IP address (from nodes.yml)
#    - Port: 2222
# 4. Click Create
# 5. Copy the SECRET_KEY shown (looks like: sk_abc123...)
# 6. Paste it below for the corresponding node-X
#
# Format: node-1, node-2, etc. (must match node names in nodes.yml)
node_secret_keys:
  node-1: "GET_SECRET_KEY_FROM_PANEL_FOR_NODE_1"
  node-2: "GET_SECRET_KEY_FROM_PANEL_FOR_NODE_2"
  # node-3: "GET_SECRET_KEY_FROM_PANEL_FOR_NODE_3"

# Reality Configuration (SAME for ALL nodes)
# Generate once with: docker run --rm teddysun/xray:latest xray x25519
# These keys are shared across all nodes - do NOT generate new ones per node
# Output format:
#   PrivateKey: xxx  ← Use this for reality_private_key (server)
#   Password: yyy    ← Use this for reality_public_key (client)
#   Hash32: zzz      ← Not needed

reality_private_key: "PASTE_PRIVATE_KEY_FROM_X25519"  # Server uses "PrivateKey" output
reality_public_key: "PASTE_PASSWORD_FROM_X25519"      # Client uses "Password" output

# Generate short ID with: openssl rand -hex 8
reality_short_id: "GENERATE_8_16_HEX_CHARS"

# =============================================================================
# CLOUDFLARE API (for Let's Encrypt DNS-01 challenge)
# =============================================================================

# Cloudflare API Token (for automatic SSL certificate generation)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# 1. Click "Create Token"
# 2. Use "Edit zone DNS" template
# 3. Select your domain (e.g., rutube.dad) under Zone Resources
# 4. Copy the token
# Required permissions: Zone:DNS:Edit for your domain
cloudflare_api_token: "YOUR_CLOUDFLARE_API_TOKEN_HERE"

# =============================================================================
# QUICK REFERENCE
# =============================================================================
# Generate secrets:
#   openssl rand -hex 32  # For JWT secrets
#   openssl rand -hex 16  # For passwords
#   openssl rand -hex 8   # For Reality short ID
#   docker run --rm teddysun/xray:latest xray x25519  # For Reality keys
#
# Generate Let's Encrypt certificates:
#   ./scripts/certs/generate-letsencrypt.sh

# =============================================================================
# PANEL API TOKEN (for programmatic config management)
# =============================================================================

# API token from Remnawave Panel (section: API Tokens)
# Used by export-config and other config management tools
remnawave_api_token: "YOUR_REMNAWAVE_API_TOKEN_HERE"
