# LAN direct access — same domains, HTTPS with internal CA
# Clients trust the CA via: vps local setup
{% for app in home_apps %}
{{ app.fqdn if app.fqdn is defined else app.subdomain ~ '.' ~ home_domain }} {
    tls internal
    reverse_proxy 127.0.0.1:{{ app.port }}
}
{% endfor %}

# Tunnel traffic — routes by Host header from VPS
:{{ xray_bridge_local_caddy_port }} {
{% for app in home_apps %}
    @{{ app.name }} host {{ app.fqdn if app.fqdn is defined else app.subdomain ~ '.' ~ home_domain }}
    handle @{{ app.name }} {
        reverse_proxy 127.0.0.1:{{ app.port }} {
            header_up X-Remote-User {header.Remote-User}
        }
    }

{% endfor %}
    handle {
        respond "Not Found" 404
    }
}
