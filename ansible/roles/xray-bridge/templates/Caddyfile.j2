# Local reverse proxy for home server apps
# Routes by Host header from the VPS tunnel

:{{ xray_bridge_local_caddy_port }} {
{% for app in home_apps %}
    @{{ app.name }} host {{ app.subdomain }}.{{ home_domain }}
    handle @{{ app.name }} {
        reverse_proxy 127.0.0.1:{{ app.port }} {
            header_up X-Remote-User {header.Remote-User}
        }
    }

{% endfor %}
    handle {
        respond "Not Found" 404
    }
}
