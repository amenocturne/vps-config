#!/bin/bash
# Minecraft world backup script

BACKUP_DIR="{{ minecraft_dir }}/backups"
DATA_DIR="{{ minecraft_dir }}/data"
MAX_BACKUPS=7
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/minecraft_backup_${TIMESTAMP}.tar.gz"

tar -czf "${BACKUP_FILE}" -C "${DATA_DIR}" world world_nether world_the_end 2>/dev/null

# Remove old backups, keep last MAX_BACKUPS
ls -t "${BACKUP_DIR}"/minecraft_backup_*.tar.gz 2>/dev/null | tail -n +$((MAX_BACKUPS + 1)) | xargs -r rm
