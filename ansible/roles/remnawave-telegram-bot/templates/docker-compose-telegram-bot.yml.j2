---
# Remnawave Telegram Bot Docker Compose
# Generated by Ansible

services:
  remnawave-telegram-bot:
    build: .
    container_name: remnawave-telegram-bot
    restart: always
    environment:
      - BOT_TOKEN={{ telegram_bot_token }}
      - REMNAWAVE_API_URL=http://remnawave:3000/api
      - ADMIN_TELEGRAM_ID={{ admin_telegram_id }}
      - REMNAWAVE_API_TOKEN={{ remnawave_api_token }}
      - SUBSCRIPTION_BASE_URL={{ subscription_base_url }}
      - MINECRAFT_RCON_HOST={{ minecraft_rcon_host | default("168.100.11.130") }}
      - MINECRAFT_RCON_PORT={{ minecraft_rcon_port | default("25575") }}
      - MINECRAFT_RCON_PASSWORD={{ minecraft_rcon_password }}
      - MINECRAFT_MANAGER_PORT={{ minecraft_manager_port | default("8585") }}
    networks:
      - remnawave-network

networks:
  remnawave-network:
    name: remnawave-network
    external: true
