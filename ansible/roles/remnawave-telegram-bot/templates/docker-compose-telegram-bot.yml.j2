---
# Remnawave Telegram Bot Docker Compose
# Generated by Ansible

services:
  remnawave-telegram-bot:
    build: .
    container_name: remnawave-telegram-bot
    restart: always
    environment:
      - BOT_TOKEN={{ telegram_bot_token }}
      - REMNAWAVE_API_URL=http://remnawave:3000/api
      - ADMIN_TELEGRAM_ID={{ admin_telegram_id }}
      - REMNAWAVE_API_TOKEN={{ remnawave_api_token }}
    networks:
      - remnawave-network

networks:
  remnawave-network:
    name: remnawave-network
    external: true
