---
# Remnawave Node Docker Compose Configuration
# Generated by Ansible

services:
  remnanode:
    container_name: remnanode
    hostname: remnanode
    image: remnawave/node:2.6.1
    network_mode: host
    restart: always
    environment:
      - NODE_PORT={{ remnawave_node_app_port }}
      - SECRET_KEY={{ remnawave_node_secret_key }}
    volumes:
      - '{{ remnawave_node_log_directory }}:{{ remnawave_node_log_directory }}'
      # SSL/TLS certificates for node API
      - '{{ remnawave_node_certs_directory }}:/etc/xray/certs:ro'
