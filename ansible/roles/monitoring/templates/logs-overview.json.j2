{
  "id": null,
  "uid": "logs-explorer",
  "title": "Logs Explorer",
  "tags": ["logs", "loki", "containers"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "query": "label_values({container=~\".+\"}, container)",
        "definition": "label_values({container=~\".+\"}, container)",
        "datasource": "Loki",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1,
        "current": {}
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": {"text": "", "value": ""},
        "hide": 0
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "query": "error,warn,info,debug",
        "multi": false,
        "includeAll": true,
        "allValue": ".+",
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Rate",
      "type": "stat",
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum(rate({container=~\"$container\"}[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 4, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "stat",
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum(rate({container=~\"$container\"} |~ \"(?i)error|exception|fatal\"[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 4, "x": 4, "y": 0}
    },
    {
      "id": 3,
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum by (container)(rate({container=~\"$container\"} |~ \"(?i)error|exception|fatal\"[$__auto]))",
          "refId": "A",
          "legendFormat": "{{ '{{' }}container{{ '}}' }}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 16, "x": 8, "y": 0}
    },
    {
      "id": 4,
      "title": "Log Volume by Container",
      "type": "timeseries",
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum by (container)(count_over_time({container=~\"$container\"}[$__auto]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 6}
    },
    {
      "id": 5,
      "title": "Logs",
      "type": "logs",
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{container=~\"$container\"} |~ \"(?i)$search\" |~ \"(?i)$level\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "gridPos": {"h": 16, "w": 24, "x": 0, "y": 12}
    },
    {
      "id": 6,
      "title": "System Journal",
      "type": "logs",
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{job=\"systemd-journal\"} |~ \"(?i)$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28}
    }
  ]
}
