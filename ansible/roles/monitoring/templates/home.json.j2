    {
      "id": 17,
      "title": "Network Traffic",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (server)(rate(node_network_receive_bytes_total{device!=\"lo\"}[1m]))",
          "legendFormat": "{{ '{{' }}server{{ '}}' }} RX",
          "refId": "A"
        },
        {
          "expr": "sum by (server)(rate(node_network_transmit_bytes_total{device!=\"lo\"}[1m]))",
          "legendFormat": "{{ '{{' }}server{{ '}}' }} TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
