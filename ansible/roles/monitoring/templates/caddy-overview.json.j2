{
  "id": null,
  "uid": "caddy-overview",
  "title": "Caddy",
  "tags": ["caddy", "reverse-proxy"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "server",
        "label": "Server",
        "type": "query",
        "query": "label_values(caddy_http_requests_total, server)",
        "datasource": "Prometheus",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(caddy_http_requests_total{server=~\"$server\"}[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value"
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Error Rate (4xx+5xx)",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(caddy_http_request_duration_seconds_count{server=~\"$server\",code=~\"[45]..\"}[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value"
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "title": "Active Connections",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(caddy_http_requests_in_flight{server=~\"$server\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value"
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 4,
      "title": "p95 Response Time",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le)(rate(caddy_http_request_duration_seconds_bucket{server=~\"$server\"}[1m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value"
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },
    {
      "id": 5,
      "title": "Request Rate by Host",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (server)(rate(caddy_http_requests_total{server=~\"$server\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{ '{{' }}server{{ '}}' }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "id": 6,
      "title": "HTTP Status Codes",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(caddy_http_request_duration_seconds_count{server=~\"$server\",code=~\"2..\"}[1m]))",
          "refId": "A",
          "legendFormat": "2xx"
        },
        {
          "expr": "sum(rate(caddy_http_request_duration_seconds_count{server=~\"$server\",code=~\"3..\"}[1m]))",
          "refId": "B",
          "legendFormat": "3xx"
        },
        {
          "expr": "sum(rate(caddy_http_request_duration_seconds_count{server=~\"$server\",code=~\"4..\"}[1m]))",
          "refId": "C",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(caddy_http_request_duration_seconds_count{server=~\"$server\",code=~\"5..\"}[1m]))",
          "refId": "D",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "2xx" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "3xx" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "id": 7,
      "title": "Response Time Percentiles",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(caddy_http_request_duration_seconds_bucket{server=~\"$server\"}[1m])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le)(rate(caddy_http_request_duration_seconds_bucket{server=~\"$server\"}[1m])))",
          "refId": "B",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le)(rate(caddy_http_request_duration_seconds_bucket{server=~\"$server\"}[1m])))",
          "refId": "C",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(caddy_http_request_duration_seconds_bucket{server=~\"$server\"}[1m])))",
          "refId": "D",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "id": 8,
      "title": "Bytes Transferred",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(caddy_http_response_size_bytes_sum{server=~\"$server\"}[1m]))",
          "refId": "A",
          "legendFormat": "Response (out)"
        },
        {
          "expr": "sum(rate(caddy_http_request_size_bytes_sum{server=~\"$server\"}[1m]))",
          "refId": "B",
          "legendFormat": "Request (in)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
    },
    {
      "id": 9,
      "title": "Requests by Server",
      "type": "table",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (server, code)(increase(caddy_http_request_duration_seconds_count{server=~\"$server\"}[$__range]))",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "sortBy": [
          { "displayName": "server", "desc": false }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true
            },
            "indexByName": {
              "server": 0,
              "code": 1,
              "Value": 2
            },
            "renameByName": {
              "Value": "Requests"
            }
          }
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 }
    }
  ]
}
