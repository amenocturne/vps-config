global:
  scrape_interval: 15s
  evaluation_interval: 15s

# rule_files:
#   - "alerts.yml"

scrape_configs:
  # === Main VPS (local) ===
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
        labels:
          server: 'vps'

  - job_name: 'node'
    static_configs:
      - targets: ['localhost:9100']
        labels:
          server: 'vps'

  - job_name: 'cadvisor'
    static_configs:
      - targets: ['localhost:8080']
        labels:
          server: 'vps'

  - job_name: 'caddy'
    static_configs:
      - targets: ['localhost:2019']
        labels:
          server: 'vps'

  - job_name: 'authelia'
    static_configs:
      - targets: ['localhost:9959']
        labels:
          server: 'vps'

  - job_name: 'loki'
    static_configs:
      - targets: ['localhost:{{ loki_port }}']
        labels:
          server: 'vps'

  - job_name: 'grafana'
    static_configs:
      - targets: ['localhost:{{ grafana_port }}']
        labels:
          server: 'vps'

  # === Remnawave panel (64.111.92.2, also covers node-1) ===
  - job_name: 'node-remnawave'
    static_configs:
      - targets: ['{{ remnawave_server_ip }}:9100']
        labels:
          server: 'remnawave'

  - job_name: 'cadvisor-remnawave'
    static_configs:
      - targets: ['{{ remnawave_server_ip }}:8081']
        labels:
          server: 'remnawave'

  # === VPN node-2 (193.149.129.84) ===
  - job_name: 'node-vpn-node-2'
    static_configs:
      - targets: ['193.149.129.84:9100']
        labels:
          server: 'node-2'

  # === Home server (tunneled via xray) ===
  - job_name: 'node-home'
    scrape_timeout: 15s
    static_configs:
      - targets: ['localhost:9101']
        labels:
          server: 'home'

  - job_name: 'cadvisor-home'
    scrape_timeout: 15s
    static_configs:
      - targets: ['localhost:9102']
        labels:
          server: 'home'

  # === Minecraft (home server, tunneled via xray) ===
  - job_name: 'minecraft'
    scrape_timeout: 15s
    static_configs:
      - targets: ['localhost:9225']
        labels:
          server: 'home'
