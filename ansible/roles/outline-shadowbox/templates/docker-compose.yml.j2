---
# Outline Shadowbox (Shadowsocks VPN)
# Generated by Ansible

services:
  shadowbox:
    container_name: shadowbox
    image: {{ outline_image }}
    network_mode: host
    restart: always
    environment:
      - SB_STATE_DIR={{ outline_state_directory }}
      - SB_API_PORT={{ outline_api_port }}
      - SB_API_PREFIX={{ outline_api_prefix }}
      - SB_CERTIFICATE_FILE={{ outline_cert_file }}
      - SB_PRIVATE_KEY_FILE={{ outline_key_file }}
      - SB_METRICS_URL=
      - SB_DEFAULT_SERVER_NAME=
    volumes:
      - '{{ outline_state_directory }}:{{ outline_state_directory }}'
    labels:
      - "com.centurylinklabs.watchtower.enable=true"

{% if outline_watchtower_enabled %}
  watchtower:
    container_name: watchtower
    image: {{ outline_watchtower_image }}
    restart: unless-stopped
    volumes:
      - '/var/run/docker.sock:/var/run/docker.sock'
    command: --cleanup --label-enable --tlsverify --interval {{ outline_watchtower_interval }}
{% endif %}
