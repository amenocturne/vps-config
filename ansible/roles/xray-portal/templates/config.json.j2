{
  "reverse": {
    "portals": [
      {
        "tag": "portal",
        "domain": "{{ xray_portal_domain }}"
      }
    ]
  },
  "inbounds": [
    {
      "tag": "external",
      "port": {{ xray_portal_listen_port }},
      "listen": "127.0.0.1",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1",
        "port": 80,
        "network": "tcp"
      }
    },
    {
      "tag": "interconn",
      "port": {{ xray_portal_interconnect_port }},
      "listen": "0.0.0.0",
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "{{ xray_tunnel_uuid }}",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "www.microsoft.com:443",
          "serverNames": ["www.microsoft.com"],
          "privateKey": "{{ xray_tunnel_private_key }}",
          "shortIds": ["{{ xray_tunnel_short_id }}"]
        }
      }
    }
  ],
  "routing": {
    "rules": [
      {
        "type": "field",
        "inboundTag": ["external"],
        "outboundTag": "portal"
      },
      {
        "type": "field",
        "inboundTag": ["interconn"],
        "outboundTag": "portal"
      }
    ]
  },
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ]
}
