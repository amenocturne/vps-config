{
  "reverse": {
    "portals": [
      {
        "tag": "portal",
        "domain": "{{ xray_portal_domain }}"
      }
    ]
  },
  "inbounds": [
    {
      "tag": "external",
      "port": {{ xray_portal_listen_port }},
      "listen": "127.0.0.1",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1",
        "port": {{ xray_portal_tunnel_http_dest | default(8080) }},
        "network": "tcp"
      }
    },
    {
      "tag": "ssh-external",
      "port": {{ xray_portal_ssh_port }},
      "listen": "0.0.0.0",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1",
        "port": 22,
        "network": "tcp"
      }
    },
    {
      "tag": "metrics-node-exporter",
      "port": 9101,
      "listen": "127.0.0.1",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1",
        "port": 9100,
        "network": "tcp"
      }
    },
    {
      "tag": "metrics-cadvisor",
      "port": 9102,
      "listen": "127.0.0.1",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1",
        "port": 8081,
        "network": "tcp"
      }
    },
    {
      "tag": "minecraft",
      "port": 25565,
      "listen": "0.0.0.0",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1",
        "port": 25565,
        "network": "tcp"
      }
    },
    {
      "tag": "minecraft-rcon",
      "port": 25575,
      "listen": "0.0.0.0",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1",
        "port": 25575,
        "network": "tcp"
      }
    },
    {
      "tag": "minecraft-metrics",
      "port": 9225,
      "listen": "127.0.0.1",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1",
        "port": 9225,
        "network": "tcp"
      }
    },
    {
      "tag": "minecraft-manager",
      "port": 8585,
      "listen": "0.0.0.0",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1",
        "port": 8585,
        "network": "tcp"
      }
    },
    {
      "tag": "interconn",
      "port": {{ xray_portal_interconnect_port }},
      "listen": "0.0.0.0",
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "{{ xray_tunnel_uuid }}",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "www.microsoft.com:443",
          "serverNames": ["www.microsoft.com"],
          "privateKey": "{{ xray_tunnel_private_key }}",
          "shortIds": ["{{ xray_tunnel_short_id }}"]
        }
      }
    }
  ],
  "routing": {
    "rules": [
      {
        "type": "field",
        "inboundTag": ["external", "ssh-external", "metrics-node-exporter", "metrics-cadvisor", "minecraft", "minecraft-rcon", "minecraft-metrics", "minecraft-manager"],
        "outboundTag": "portal"
      },
      {
        "type": "field",
        "inboundTag": ["interconn"],
        "outboundTag": "portal"
      }
    ]
  },
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ]
}
