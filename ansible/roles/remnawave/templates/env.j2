# Remnawave Panel Configuration
# Auto-generated by Ansible - Do not edit manually

# Application Configuration
APP_PORT={{ remnawave_app_port }}
METRICS_PORT={{ remnawave_metrics_port }}
API_INSTANCES=1

# Domain Configuration
FRONT_END_DOMAIN={{ remnawave_frontend_domain }}
SUB_PUBLIC_DOMAIN={{ remnawave_sub_domain }}

# Security Secrets (Auto-generated)
JWT_AUTH_SECRET={{ jwt_auth_secret }}
JWT_API_TOKENS_SECRET={{ jwt_api_tokens_secret }}
METRICS_USER=admin
METRICS_PASS={{ metrics_pass }}
WEBHOOK_SECRET_HEADER={{ webhook_secret }}

# Database Configuration
POSTGRES_USER=remnawave
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB=remnawave
DATABASE_URL=postgresql://remnawave:{{ postgres_password }}@remnawave-db:5432/remnawave

# Redis Configuration
REDIS_HOST=remnawave-redis
REDIS_PORT=6379

# Telegram Notifications (disabled by default)
IS_TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_USERS_CHAT_ID=
TELEGRAM_NOTIFY_NODES_CHAT_ID=
TELEGRAM_NOTIFY_CRM_CHAT_ID=
TELEGRAM_NOTIFY_USERS_THREAD_ID=
TELEGRAM_NOTIFY_NODES_THREAD_ID=
TELEGRAM_NOTIFY_CRM_THREAD_ID=

# Documentation (disabled by default)
SWAGGER_PATH=/docs
SCALAR_PATH=/scalar
IS_DOCS_ENABLED=false

# Webhooks (disabled by default)
WEBHOOK_ENABLED=false
WEBHOOK_URL=

# Device Detection (disabled by default)
HWID_DEVICE_LIMIT_ENABLED=false

# Notifications (disabled by default)
BANDWIDTH_USAGE_NOTIFICATIONS_ENABLED=false
BANDWIDTH_USAGE_NOTIFICATIONS_THRESHOLD=[60, 80]
NOT_CONNECTED_USERS_NOTIFICATIONS_ENABLED=false
NOT_CONNECTED_USERS_NOTIFICATIONS_AFTER_HOURS=[6, 24, 48]

# Trust node's self-signed CA certificate for secure node health checks
# If certificate extraction fails during deployment, this falls back to system default
NODE_EXTRA_CA_CERTS=/etc/ssl/certs/node-ca.pem

